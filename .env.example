# ─── Required ──────────────────────────────────────────────────────────────
# Your actual LLM API key (clients send any string, gateway uses this)
TARGET_API_KEY=sk-your-actual-openai-key-here

# ─── Target LLM ────────────────────────────────────────────────────────────
TARGET_API_URL=https://api.openai.com
TARGET_PROVIDER=openai      # openai | anthropic | mistral | custom
# TARGET_API_URL=https://api.anthropic.com
# TARGET_PROVIDER=anthropic

# ─── Gateway Authentication ────────────────────────────────────────────────
# Comma-separated list of API keys for clients connecting to SovereignGuard
# GATEWAY_API_KEYS=sg-key-abc123,sg-key-def456
# If empty, the gateway is open to all clients (development only)

# ─── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (empty = allow all)
# ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# ─── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPM=60           # Requests per minute per IP

# ─── Masking ───────────────────────────────────────────────────────────────
MAPPING_BACKEND=memory       # memory | local | redis
ENABLED_LOCALES=universal,tn,fr,ma
CONFIDENCE_THRESHOLD=0.7

# ─── Policy Engine (RBAC) ─────────────────────────────────────────────────
# POLICY_FILE=./policies.json

# ─── Smart Sovereign Routing (local fallback for high sensitivity) ───────
LOCAL_FALLBACK_ENABLED=false
# LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3
SENSITIVITY_THRESHOLD=0.90

# ─── Circuit Breaker (fail-closed on masking/encryption failures) ─────────
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIMEOUT=60

# ─── HashiCorp Vault (optional secure mapping backend) ────────────────────
VAULT_ENABLED=false
# VAULT_URL=http://127.0.0.1:8200
# VAULT_TOKEN=your-vault-token
VAULT_MOUNT_PATH=secret
VAULT_PREFIX=sovereignguard/sessions

# ─── Encryption (auto-generated if not set — set explicitly for production)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ENCRYPTION_KEY=your-base64-encoded-key

# ─── Redis (for MAPPING_BACKEND=redis) ─────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
MAPPING_TTL_SECONDS=3600

# ─── Audit ─────────────────────────────────────────────────────────────────
AUDIT_LOGGING_ENABLED=true
AUDIT_LOG_PATH=./logs/audit.jsonl

# ─── Metrics ───────────────────────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_PORT=9090

# ─── Performance ───────────────────────────────────────────────────────────
WORKERS=4
MAX_REQUEST_SIZE_MB=10
REQUEST_TIMEOUT_SECONDS=60

# ─── Development ───────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=info
BYPASS_MASKING=false    # NEVER true in production
